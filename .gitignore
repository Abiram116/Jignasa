# Generated RAG index (rebuild via pipeline/, keep folder via .gitkeep)
rag_index/*
!rag_index/.gitkeep
!rag_index/README.md

# Local PDFs (add your own; too large for GitHub)
knowledge-base/*.pdf

# Evaluation run outputs (ad-hoc snapshots from the UI/CLI are noise;
# the canonical benchmark results below are kept and committed)
data/evaluations/*
!data/evaluations/README.md
!data/evaluations/v2_post_rebuild.csv
!data/evaluations/ragas_v1.csv
!data/evaluations/ragas_v1_summary.json

# --- Logs ---
*.log
logs/

# --- Streamlit ---
.streamlit/secrets.toml

# --- React web app ---
web/node_modules/
web/dist/
web/dev-dist/
web/.eslintcache
web/*.log
web/npm-debug.log*
web/yarn-debug.log*
web/yarn-error.log*
web/pnpm-debug.log*

# --- Windows / WSL artifacts ---
*:Zone.Identifier

# --- Temporary Test Folders ---
test UI/

# --- Agent skills (fetched content, local dev tooling only) ---
.agents/
.claude/
skills-lock.json

# --- Stray dev artifacts (not source, not meant to be committed) ---
all_changes.patch
